# Required only when enabling Google login and cloud persistence.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional. Without these, SQLMate uses a no-cost local fallback for hints and extra questions.
OPENAI_API_KEY=
OPENAI_MODEL=

# Optional. When set, /api/sql can run EXPLAIN for safe read-only SQL.
DATABASE_URL=
